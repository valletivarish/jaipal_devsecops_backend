[flake8]
# Maximum line length matching pylint config
max-line-length = 100
# Maximum cyclomatic complexity per function
max-complexity = 10
# Exclude common non-source directories
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    env,
    dist,
    build
# Ignore specific rules that conflict with FastAPI patterns
# E501: line too long (handled by max-line-length)
# W503: line break before binary operator (PEP 8 now prefers this)
ignore = W503
# Output format for CI/CD integration
format = default
# Show source code for each error
show-source = true
# Count total errors
count = true
